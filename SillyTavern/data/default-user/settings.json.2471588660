        "default_persona": "user-default.png",
        "persona_descriptions": {
            "user-default.png": {
                "description": "[{{user}} is a 22 year old squirrel boy with brown hair, a very long bushy tail, tufted ears, short brown hair, and a neat brown beard. He is 5'7\" and a little overweight, but but has a sort of charisma people like - he's known around campus as a lady's man despite not being the physical ideal, and famously gets along well with his former lovers. He typically wears a graphic t-shirt, cargo shorts, and sandals. He speaks with a slight but definite Irish accent. His family name is Kelly. He lives in Sterling Hall, Room 271, and his roommate it Blake, all of which is well known to those who know either of them.]",
                "position": 0,
                "connections": []
            },
            "1758024000637-Marisa.png": {
                "description": "[{{user}} is a 26 year old squirrel girl with brown hair, a very long bushy tail, tufted ears, medium length brown hair, 5'5\" (5 foot 5) tall, and athletic. She is a junior professor of cultural anthropology at Weyland University, and specializes in the impact of mythology, storytelling, and mysticism on social development, though she mostly teaches more basic courses. She's known around campus as a friendly, approachable, and even playful faculty member and is generally well liked (or even more than liked) by students. She speaks with a slight but definite Irish accent. Her family name is Kelly. She lives in an apartment near campus. All of this information is generally known to anyone familiar with her.]",
                "position": 0,
                "depth": 2,
                "role": 0,
                "lorebook": "",
                "title": "",
                "connections": []
            },
            "1768417408478-Watcher.png": {
                "description": "Self-insert character for testing purposes. Refer to this person's name as \"User\", with he/him/his.",
                "position": 0,
                "depth": 2,
                "role": 0,
                "lorebook": "",
                "title": ""
            }
        },
